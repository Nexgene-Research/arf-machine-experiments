# Optional absolute-path overrides.
# When unset, paths resolve from the arf-machine-experiments repo root:
#   data/emeraldbay
#   data/rhaister_data
#   data/Rhaister

# ARF_MACHINE_EXPERIMENTS_ROOT=/absolute/path/to/arf-machine-experiments
# EMERALDBAY_DATA_ROOT=/absolute/path/to/data/emeraldbay
# RHAISTER_DATA_ROOT=/absolute/path/to/data/rhaister_data
# EMERALDBAY_EXPRESSION_FEATURES=/absolute/path/to/data/rhaister_data/EmeraldBay/expression_means_2k.parquet
# RHAISTER_REPO=/absolute/path/to/data/Rhaister

# Windows: avoid UnicodeEncodeError in Rhaister logs
# PYTHONUTF8=1
